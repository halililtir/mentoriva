# ===============================
# MENTORIVA ENVIRONMENT VARIABLES
# ===============================
# Bu dosya bir şablondur. Gerçek .env.local dosyanızı bu örneğe göre oluşturun.
# Production'da bu değerler Vercel Dashboard > Environment Variables'dan girilir.
# ASLA .env.local dosyasını git'e commit etmeyin.

# Anthropic Claude API
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Vercel KV (rate limiting ve future session storage için)
# Vercel Dashboard > Storage > Create Database > KV
# KV oluştururken tüm 4 değişken otomatik eklenir
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Site URL (canonical links ve OpenGraph için)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Feature Flags (opsiyonel, varsayılanlar lib/features.ts'de)
# NEXT_PUBLIC_FEATURE_CHAT_ENABLED=true
# NEXT_PUBLIC_FEATURE_ANALYTICS_ENABLED=false

# Admin Panel (geri bildirimleri görmek için)
# /admin sayfasında bu anahtar sorulur
ADMIN_SECRET=121017
